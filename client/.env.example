# Main backend (auth, admin, users, subscriptions, payments, news, ads, notifications)
VITE_API_URL=http://localhost:5000/api/v1

# PlusOne bridge (matches, predictions, team/player stats)
VITE_BRIDGE_URL=http://localhost:5050/api/v1

# Must match backend's VAPID_PUBLIC_KEY (generate both together via
# `npm run generate-vapid` in backend/)
VITE_VAPID_PUBLIC_KEY=
